# Asistente IA (OpenRouter) — requerido SOLO para el asistente /asistente
# Obtén tu clave en https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-tu-api-key

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Site URL (requerido para OAuth redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google OAuth: se configura en Supabase Dashboard, NO aquí
# Ver: Supabase Dashboard > Authentication > Providers > Google
